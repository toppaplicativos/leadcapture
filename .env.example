# Exemplo de arquivo .env para PWA e Push Notifications

# ===== VAPID Keys para Web Push Notifications =====
# Gere com: npx web-push generate-vapid-keys
# Coloque a chave pública também no frontend ao chamar subscribeToPushNotifications()

VAPID_PUBLIC_KEY="sua-chave-publica-aqui"
VAPID_PRIVATE_KEY="sua-chave-privada-aqui"
VAPID_EMAIL="seu-email@example.com"

# ===== Frontend URL =====
# Usada para CORS e notificações
FRONTEND_URL="http://127.0.0.1:3003"

# ===== Configurações gerais do servidor =====
NODE_ENV="development"
PORT=3000

# ===== Atlas Cloud (provider unificado: texto, imagem, vídeo, áudio) =====
# Console: https://www.atlascloud.ai/console/api-keys
# Docs: https://atlascloud.ai/docs/en/
# ATLAS_API_KEY="sua-chave-atlas"
# ATLAS_BASE_URL="https://api.atlascloud.ai"
# ATLAS_MODEL="google/gemini-2.5-flash"

# ===== Payment Engine =====
# Chave usada para criptografar segredos de gateways no banco
# Em produção, use um valor forte e único
PAYMENT_ENCRYPTION_KEY="troque-por-uma-chave-segura"

# Base pública usada para retorno dos checkouts (Stripe/Mercado Pago)
CHECKOUT_BASE_URL="http://127.0.0.1:3003"

# Opcional: URL pública do frontend (fallback para checkout)
FRONTEND_PUBLIC_URL="http://127.0.0.1:3003"
