# ai-model-studio:toppaimodel.online
toppaimodel.online, www.toppaimodel.online, app.toppaimodel.online, adm.toppaimodel.online {
    encode gzip

    reverse_proxy 127.0.0.1:5000 {
        transport http {
            read_timeout 5m
            write_timeout 5m
            dial_timeout 30s
        }
    }

    header Cache-Control "no-cache, no-store, must-revalidate"
}



