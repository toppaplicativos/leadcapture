# LeadCapture Connect — referência local (NÃO injeta BuildConfig).
# Configure API em gradle.properties:
#   API_BASE_URL=https://app.leadcapture.online/
#   AI_PROVIDER=atlas
#
# IA (Atlas Cloud) roda no backend LeadCapture — mesmo provider do painel Admin.
# O app Android NÃO precisa de GEMINI_API_KEY.

API_BASE_URL=https://app.leadcapture.online/
AI_PROVIDER=atlas
